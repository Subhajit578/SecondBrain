# Copy to .env and fill in real values. Never commit .env.

# Long random string (e.g. openssl rand -hex 32)
JWT_SECRET=change-me-to-a-long-random-string

# MongoDB Atlas — URL-encode special characters in the password
MONGODB_URI=mongodb+srv://DB_USER:DB_PASSWORD@cluster.mongodb.net/secondbrain

# Public URL of your app (used by backend if needed)
FRONTEND_PUBLIC_URL=http://18.221.223.197

# Baked into frontend at docker build time — same host, no port (nginx proxies /app and /api)
VITE_BACKEND_URL=http://18.221.223.197

PORT=3000

# No space after =
OPENAI_API_KEY=sk-your-openai-key-here

# --- Local dev only (npm run dev, no Docker) ---
# FRONTEND_PUBLIC_URL=http://localhost:5173
# VITE_BACKEND_URL=http://localhost:3000
